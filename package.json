{
  "name": "coortex",
  "version": "0.1.0",
  "private": true,
  "description": "Host-agnostic runtime-first coordination layer for coding assistants.",
  "type": "module",
  "bin": {
    "ctx": "dist/cli/ctx.js"
  },
  "scripts": {
    "build": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true});\" && tsc",
