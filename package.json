    "test:live-m2": "npm run build && node --test dist/__tests__/milestone-2-live-harness.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "6.0.2"
  }
}
